# ── Environment ─────────────────────────────────────
# Must be one of: local, development, production
NODE_ENV=local

# ── Server ──────────────────────────────────────────
PORT=5000

# ── Database ────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/alumnext

# ── JWT ─────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# ── CORS ────────────────────────────────────────────
CLIENT_URL=http://localhost:5173
